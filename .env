# API Keys para los agentes AI (opcional - pone tus propias keys)

# Anthropic - Claude Code
ANTHROPIC_API_KEY=your-api-key-here

# OpenAI - Codex CLI
OPENAI_API_KEY=your-api-key-here

# Google - Gemini CLI
GEMINI_API_KEY=your-api-key-here
