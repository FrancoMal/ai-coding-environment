        {
            showConnectMenu = false;
            return;
        }

        mlError = null;
        try
        {
            var response = await Api.GetMeliAuthUrlAsync();
            if (response is not null && !string.IsNullOrEmpty(response.AuthUrl))
            {
                meliAuthUrl = response.AuthUrl;
                showConnectMenu = true;
                urlCopied = false;
            }
            else
            {
                ToastService.Error("No se pudo obtener la URL de autorizacion. Verifica la configuracion.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al obtener URL: " + ex.Message);
        }
