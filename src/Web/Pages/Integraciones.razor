    {
        showDeleteConfirm = false;
        deleteStats = null;
        deleteConfirmText = "";
    }

    private async Task ConfirmRemoveAccount()
    {
        if (deleteStats == null || deleteConfirmText != deleteStats.Nickname) return;
        deletingAccount = true;

        try
        {
            var deleted = await Api.DeleteMeliAccountAsync(accountToDelete);
            if (deleted)
            {
                ToastService.Success("Cuenta " + deleteStats.Nickname + " desconectada y datos eliminados");
                CloseDeleteModal();
                await LoadAccounts();
            }
        }
        catch
        {
            ToastService.Error("Error al quitar la cuenta");
        }
        finally
        {
            deletingAccount = false;
        }
    }
}
