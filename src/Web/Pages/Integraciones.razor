                    @(claudeSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Quitar cuenta -->
@if (showDeleteConfirm && deleteStats != null)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #fff3f3;">
                <h3 style="color: var(--danger);">Quitar cuenta: @deleteStats.Nickname</h3>
                <button class="btn-close" @onclick="CloseDeleteModal">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
                    <strong style="color: #856404;">Atencion:</strong>
                    <span style="color: #856404;"> Esta accion eliminara de la base de datos local todos los datos asociados a esta cuenta.</span>
                </div>

                <p style="margin-bottom: 0.5rem;">Se van a eliminar los siguientes datos:</p>
                <ul style="margin: 0.5rem 0 1rem 1.5rem; line-height: 1.8;">
                    <li><strong>@deleteStats.OrderCount ordenes</strong> sincronizadas</li>
                    <li><strong>@deleteStats.ItemCount publicaciones</strong> sincronizadas</li>
                    <li>La conexion y tokens de acceso de la cuenta</li>
                </ul>

                <div style="background: #d4edda; border: 1px solid #28a745; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
                    <strong style="color: #155724;">Importante:</strong>
                    <span style="color: #155724;"> NO se eliminara nada de MercadoLibre. Tus ordenes, publicaciones y datos en MercadoLibre no se van a modificar. Solo se borran los datos de esta aplicacion.</span>
                </div>

                <div class="form-group" style="margin-top: 1rem;">
                    <label class="form-label">Para confirmar, escribi <strong>@deleteStats.Nickname</strong> en el campo de abajo:</label>
                    <input type="text" class="form-input" @bind="deleteConfirmText" @bind:event="oninput" placeholder="Escribi el nombre de la cuenta..."
                           style="@(deleteConfirmText.Length > 0 && deleteConfirmText != deleteStats.Nickname ? "border-color: #dc3545;" : "")" />
                    @if (deleteConfirmText.Length > 0 && deleteConfirmText != deleteStats.Nickname)
                    {
                        <small style="color: #dc3545; margin-top: 0.25rem; display: block;">El texto no coincide. Escribi exactamente <strong>@deleteStats.Nickname</strong> para confirmar.</small>
                    }
                    else if (string.IsNullOrEmpty(deleteConfirmText))
                    {
                        <small style="color: #856404; margin-top: 0.25rem; display: block;">Debes completar este campo para confirmar la eliminacion.</small>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmRemoveAccount"
                        disabled="@(deleteConfirmText != deleteStats.Nickname || deletingAccount)">
                    @(deletingAccount ? "Eliminando..." : "Quitar cuenta y datos")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Configuracion Email SMTP -->
@if (showEmailModal)
{
    <div class="modal-overlay" @onclick="CloseEmailModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Configuracion de Email</h3>
                <button class="btn-close" @onclick="CloseEmailModal">&times;</button>
            </div>
            <div class="modal-body">
                <h4 style="margin-bottom: 0.75rem; color: var(--text-primary);">Envio (SMTP)</h4>
                <div class="form-row">
                    <div class="form-group" style="flex:2">
                        <label class="form-label">Servidor SMTP</label>
                        <input type="text" class="form-input" @bind="emailSmtpHost" placeholder="smtp.gmail.com" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Puerto</label>
                        <input type="number" class="form-input" @bind="emailSmtpPort" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailSmtpTls" /> Usar TLS/SSL
                    </label>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Nombre remitente</label>
                        <input type="text" class="form-input" @bind="emailFromName" placeholder="Mi Empresa" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Email remitente</label>
                        <input type="email" class="form-input" @bind="emailFromAddress" placeholder="info@empresa.com" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Usuario</label>
                        <input type="text" class="form-input" @bind="emailUsername" placeholder="Igual al email si no se especifica" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Contraseña</label>
                        <input type="password" class="form-input" @bind="emailPassword"
                               placeholder="@(emailHasSecret ? "••••••••  (ya configurada)" : "Contraseña o App Password")" />
                    </div>
                </div>

                <hr style="margin: 1.25rem 0; border: none; border-top: 1px solid var(--border);" />

                <h4 style="margin-bottom: 0.75rem; color: var(--text-primary);">Lectura (IMAP)</h4>
                <div class="form-row">
                    <div class="form-group" style="flex:2">
                        <label class="form-label">Servidor IMAP</label>
                        <input type="text" class="form-input" @bind="emailImapHost" placeholder="imap.gmail.com" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Puerto</label>
                        <input type="number" class="form-input" @bind="emailImapPort" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailImapTls" /> Usar TLS/SSL
                    </label>
                </div>

                <hr style="margin: 1.25rem 0; border: none; border-top: 1px solid var(--border);" />

                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailActive" /> Activo
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                @if (emailId > 0)
                {
                    <button class="btn btn-danger" @onclick="DeleteEmail" disabled="@emailSaving" style="margin-right: auto;">
                        Eliminar
                    </button>
                }
                <button class="btn btn-outline-primary" @onclick="TestEmail" disabled="@(emailSaving || emailTesting)">
                    @(emailTesting ? "Enviando..." : "Enviar prueba")
                </button>
                <button class="btn btn-secondary" @onclick="CloseEmailModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveEmail" disabled="@emailSaving">
                    @(emailSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

