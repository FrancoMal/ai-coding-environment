        {
            sortColumn = column;
            sortAsc = true;
        }
    }

    // --- Text Filters ---
    private void SetTextFilter(string column, string value)
    {
        textFilters[column] = value;
    }

    private string GetTextFilter(string column)
    {
        return textFilters.TryGetValue(column, out var val) ? val : "";
    }

    private bool IsFilterActive(string column)
    {
        return textFilters.TryGetValue(column, out var tv) && !string.IsNullOrEmpty(tv);
    }

    // --- Checkbox Filters ---
    private void ToggleDropdownFilter(string column)
    {
        if (activeFilterColumn == column)
            activeFilterColumn = null;
        else
            activeFilterColumn = column;
    }

    private void ToggleCheckboxValue(string column, string value)
    {
        if (!checkboxFilters.ContainsKey(column))
            checkboxFilters[column] = new HashSet<string>();
        if (!checkboxFilters[column].Remove(value))
            checkboxFilters[column].Add(value);
    }

    private bool IsCheckboxChecked(string column, string value)
    {
        return checkboxFilters.TryGetValue(column, out var set) && set.Contains(value);
    }

    private bool IsCheckboxFilterActive(string column)
    {
        return checkboxFilters.TryGetValue(column, out var cv) && cv.Count > 0;
    }

    private List<string> GetUniqueValues(string column)
    {
        if (items is null) return new();
        var values = column switch
        {
            "estado" => items.Select(i => GetStatusLabel(i.Status)).Distinct(),
            "tipo" => items.Select(i => GetListingTypeLabel(i.ListingTypeId)).Distinct(),
            "cuenta" => items.Select(i => i.AccountNickname).Distinct(),
            _ => Enumerable.Empty<string>()
        };
        return values.OrderBy(v => v).ToList();
    }

    private void ClearCheckboxFilter(string column)
    {
        checkboxFilters.Remove(column);
        activeFilterColumn = null;
    }

    private void CloseAllDropdowns()
    {
        activeFilterColumn = null;
    }

    // --- Filtered + Sorted ---
    private List<MeliItemDto> GetFilteredAndSortedItems()
    {
        if (items is null) return new();

        var filtered = items.AsEnumerable();

        // Promo filter
        if (filterPromo)
            filtered = filtered.Where(i => i.OriginalPrice.HasValue && i.OriginalPrice.Value > 0 && i.OriginalPrice.Value != i.Price);

        // Text filters
        foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var search = kv.Value;
            filtered = kv.Key switch
            {
                "titulo" => filtered.Where(i =>
                    i.Title.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    i.MeliItemId.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (i.FamilyId ?? "").Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (i.UserProductId ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                "sku" => filtered.Where(i => (i.Sku ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                _ => filtered
            };
        }

        // Checkbox filters
        foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
        {
            var values = kv.Value;
            filtered = kv.Key switch
            {
                "estado" => filtered.Where(i => values.Contains(GetStatusLabel(i.Status))),
                "tipo" => filtered.Where(i => values.Contains(GetListingTypeLabel(i.ListingTypeId))),
                "cuenta" => filtered.Where(i => values.Contains(i.AccountNickname)),
                _ => filtered
            };
        }

        var list = filtered.ToList();

        // Sort
        if (sortColumn is not null)
        {
            list = sortColumn switch
            {
                "titulo" => sortAsc ? list.OrderBy(i => i.Title).ToList() : list.OrderByDescending(i => i.Title).ToList(),
                "sku" => sortAsc ? list.OrderBy(i => i.Sku).ToList() : list.OrderByDescending(i => i.Sku).ToList(),
                "precio" => sortAsc ? list.OrderBy(i => i.Price).ToList() : list.OrderByDescending(i => i.Price).ToList(),
                "stock" => sortAsc ? list.OrderBy(i => i.AvailableQuantity).ToList() : list.OrderByDescending(i => i.AvailableQuantity).ToList(),
                "vendidos" => sortAsc ? list.OrderBy(i => i.SoldQuantity).ToList() : list.OrderByDescending(i => i.SoldQuantity).ToList(),
                "estado" => sortAsc ? list.OrderBy(i => i.Status).ToList() : list.OrderByDescending(i => i.Status).ToList(),
                "tipo" => sortAsc ? list.OrderBy(i => i.ListingTypeId).ToList() : list.OrderByDescending(i => i.ListingTypeId).ToList(),
                "cuenta" => sortAsc ? list.OrderBy(i => i.AccountNickname).ToList() : list.OrderByDescending(i => i.AccountNickname).ToList(),
                _ => list
            };
        }

        return list;
    }

    // --- Grouping ---
    private List<FamilyGroup> GetFamilyGroups()
    {
        var filtered = GetFilteredAndSortedItems();
        return filtered
            .GroupBy(i => i.FamilyId ?? "__none__")
            .Select(g => new FamilyGroup
            {
                FamilyId = g.Key,
                FamilyName = g.First().FamilyName ?? "Sin familia",
                Items = g.ToList()
            })
            .OrderBy(g => g.FamilyName == "Sin familia" ? 1 : 0)
            .ThenBy(g => g.FamilyName)
            .ToList();
    }

    private List<ProductGroup> GetProductGroups()
    {
        var filtered = GetFilteredAndSortedItems();
        return filtered
            .GroupBy(i => i.UserProductId ?? i.MeliItemId)
            .Select(g => new ProductGroup
            {
                UserProductId = g.Key,
                Title = g.First().Title,
                Items = g.ToList()
            })
            .OrderBy(g => g.Title)
            .ToList();
