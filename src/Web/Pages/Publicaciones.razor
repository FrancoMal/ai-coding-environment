    // View mode
    private string viewMode = "flat";
    private bool filterPromo = false;

    private void TogglePromoFilter()
    {
        filterPromo = !filterPromo;
    }

    // Sort state
    private string? sortColumn;
    private bool sortAsc = true;

    // Text filter state
    private Dictionary<string, string> textFilters = new();

    // Checkbox filter state
    private string? activeFilterColumn;
    private Dictionary<string, HashSet<string>> checkboxFilters = new()
    {
        ["estado"] = new HashSet<string> { "Activa" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
        try { meliAccounts = await Api.GetMeliAccountsAsync(); } catch { }
    }

    private async Task LoadItems()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Api.GetMeliItemsAsync();
            if (response is not null)
            {
                items = response.Items;
                totalItems = response.Total;
            }
        }
        catch
        {
            ToastService.Error("Error al cargar las publicaciones");
            items = new();
        }

        isLoading = false;
    }

    private void ToggleSyncMenu()
    {
        showSyncMenu = !showSyncMenu;
    }

    private async Task SyncItems(string? status, int? accountId)
    {
        showSyncMenu = false;
        isSyncing = true;

        // Build descriptive label
        if (status is not null)
            syncingLabel = $"Sincronizando {GetStatusLabel(status)}s...";
        else if (accountId.HasValue && meliAccounts is not null)
        {
            var acc = meliAccounts.FirstOrDefault(a => a.Id == accountId.Value);
            syncingLabel = $"Sincronizando {acc?.Nickname ?? "cuenta"}...";
        }
        else
            syncingLabel = "Sincronizando todo...";

        StateHasChanged();

        try
        {
            var result = await Api.SyncMeliItemsAsync(status, accountId);
            if (result is not null)
            {
                if (result.TotalErrors > 0)
                    ToastService.Warning($"Sincronizados {result.TotalSynced} items con {result.TotalErrors} errores");
                else
                    ToastService.Success($"Sincronizados {result.TotalSynced} items");
            }
            await LoadItems();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al sincronizar: " + ex.Message);
        }

        isSyncing = false;
    }

