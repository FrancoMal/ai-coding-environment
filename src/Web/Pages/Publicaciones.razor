    private async void OpenItemModal(MeliItemDto item)
    {
        selectedItem = item;
        editTitle = item.Title;
        editFamilyName = item.FamilyName ?? "";
        editPrice = item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 ? item.OriginalPrice.Value : item.Price;
        editPriceFormatted = FormatPrice(editPrice);
        editStock = item.AvailableQuantity;
        editStatus = item.Status;
        itemPromotions = null;
        isLoadingPromotions = false;
        showOtherCampaigns = false;
        itemCosts = null;
        isLoadingCosts = false;
        showItemModal = true;
        StateHasChanged();

        // Load promotion details if item is in promotion
        if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
        {
            isLoadingPromotions = true;
            StateHasChanged();
            try
            {
                itemPromotions = await Api.GetItemPromotionsAsync(item.MeliItemId);
            }
            catch
            {
                itemPromotions = new();
            }
            isLoadingPromotions = false;
            StateHasChanged();
        }


        // Load tax percentage from localStorage for this MeLi account
        try
        {
            var taxKey = $"meli_tax_pct_{item.MeliAccountId}";
            var savedTax = await JS.InvokeAsync<string?>("localStorage.getItem", taxKey);
            if (!string.IsNullOrEmpty(savedTax) && decimal.TryParse(savedTax, NumberStyles.Any, CultureInfo.InvariantCulture, out var savedPct))
                taxPercentage = savedPct;
            else
                taxPercentage = 0;
        }
        catch
        {
            taxPercentage = 0;
        }
        // Load cost simulator
        isLoadingCosts = true;
        StateHasChanged();
        try
        {
            itemCosts = await Api.GetItemCostsAsync(item.MeliItemId);
        }
        catch
        {
            itemCosts = null;
        }
        isLoadingCosts = false;
        StateHasChanged();
    }

    private string FormatTaxPct() => taxPercentage == 0 ? "0" : taxPercentage.ToString("0.##", CultureInfo.InvariantCulture);

    private decimal CalculateTaxAmount()
    {
        if (itemCosts is null) return 0;
        return Math.Round(itemCosts.Price * taxPercentage / 100m, 2);
    }

    private decimal CalculateNetAmount()
    {
        if (itemCosts is null) return 0;
        var taxes = CalculateTaxAmount();
        return Math.Round(itemCosts.Price - itemCosts.SaleFeeAmount - itemCosts.ListingFeeAmount - itemCosts.ShippingCost - taxes, 2);
    }

    private async Task OnTaxPercentageChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        raw = raw.Replace('.', ',');
        if (decimal.TryParse(raw, NumberStyles.Any, argCulture, out var pct))
        {
            taxPercentage = Math.Max(0, Math.Min(100, pct));
        }
        else if (string.IsNullOrWhiteSpace(raw))
        {
            taxPercentage = 0;
        }
        // Save to localStorage per MeLi account
        if (selectedItem is not null)
        {
            var key = $"meli_tax_pct_{selectedItem.MeliAccountId}";
            await JS.InvokeVoidAsync("localStorage.setItem", key, taxPercentage.ToString(CultureInfo.InvariantCulture));
        }
    }

    private string GetPromoTypeLabel(string type) => type switch
    {
        "DEAL" => "Tradicional",
        "MARKETPLACE_CAMPAIGN" => "Co-fondeada",
        "VOLUME" => "Descuento por volumen",
        "DOD" => "Oferta del dia",
        "LIGHTNING" => "Oferta relampago",
        "PRE_NEGOTIATED" => "Descuento pre-acordado por item",
        "SELLER_CAMPAIGN" => "Campaña del vendedor",
        "SMART" => "Campaña co-fondeada automatizada",
        "PRICE_MATCHING" => "Campaña de precios competitivos",
        "UNHEALTHY_STOCK" => "Campaña de liquidacion stock Full",
        "PRICE_DISCOUNT" => "Descuento de precio",
        _ => type
    };

    private bool IsCoFunded(string type) =>
        type == "SMART" || type == "PRICE_MATCHING" || type == "MARKETPLACE_CAMPAIGN" || type == "PRE_NEGOTIATED";

    private string GetPromoStatusLabel(string status) => status switch
    {
        "started" => "Activa",
        "candidate" => "Candidata",
        "finished" => "Finalizada",
        "pending" => "Pendiente",
        _ => status
    };

    private string GetPromoStatusClass(string status) => status switch
    {
        "started" => "status-active",
        "candidate" => "status-paused",
        "finished" => "status-closed",
        _ => ""
    };

    private RenderFragment RenderCampaignCard(ItemPromotionDto promo) => __builder =>
    {
        <div class="promo-campaign-card">
            <div class="promo-campaign-header">
                <span class="promo-campaign-name">@(string.IsNullOrEmpty(promo.Name) ? GetPromoTypeLabel(promo.Type) : promo.Name)</span>
                <span class="promo-type-badge @(IsCoFunded(promo.Type) ? "cofunded" : "")">@GetPromoTypeLabel(promo.Type)</span>
                <span class="promo-campaign-status status-badge @GetPromoStatusClass(promo.Status)">@GetPromoStatusLabel(promo.Status)</span>
            </div>
            @if (promo.PromotionPrice.HasValue && promo.PromotionPrice.Value > 0 && promo.OriginalPrice.HasValue && promo.OriginalPrice.Value > 0)
            {
                var promoDesc = promo.OriginalPrice.Value - promo.PromotionPrice.Value;
                var promoPctTotal = promoDesc / promo.OriginalPrice.Value * 100;
                <div class="promo-info-header">
                    <span class="promo-label">En promocion</span>
                    <span class="promo-discount-badge">-@promoPctTotal.ToString("N1")%</span>
                </div>
                <div class="promo-content-row">
                    <div class="promo-prices-side">
                        <div class="promo-price-col">
                            <span class="promo-price-label">Original</span>
                            <span class="promo-original">@selectedItem.CurrencyId @promo.OriginalPrice.Value.ToString("N2")</span>
                        </div>
                        <div class="promo-price-col">
                            <span class="promo-price-label">Ahorro</span>
                            <span class="promo-discount">-@selectedItem.CurrencyId @promoDesc.ToString("N2")</span>
                        </div>
                        <div class="promo-price-col">
                            <span class="promo-price-label">Precio final</span>
                            <span class="promo-sale">@selectedItem.CurrencyId @promo.PromotionPrice.Value.ToString("N2")</span>
                        </div>
                    </div>
                    @if (IsCoFunded(promo.Type) && (promo.MeliPercentage.HasValue || promo.SellerPercentage.HasValue))
                    {
                        var meliPct = promo.MeliPercentage.GetValueOrDefault();
                        var sellerPct = promo.SellerPercentage.GetValueOrDefault();
                        var meliAmount = promo.OriginalPrice.Value * meliPct / 100;
                        var sellerAmount = promo.OriginalPrice.Value * sellerPct / 100;
                        <div class="promo-breakdown-side">
                            @if (sellerPct > 0)
                            {
                                <span class="promo-legend-item">
                                    <span class="promo-legend-dot seller-dot"></span>
                                    A tu cargo: @sellerPct.ToString("N1")% (-$@sellerAmount.ToString("N2"))
                                </span>
                            }
                            @if (meliPct > 0)
                            {
                                <span class="promo-legend-item">
                                    <span class="promo-legend-dot meli-dot"></span>
                                    MercadoLibre: @meliPct.ToString("N1")% (-$@meliAmount.ToString("N2"))
                                </span>
                            }
                        </div>
                    }
                </div>
            }
            else if (!IsCoFunded(promo.Type) && promo.PromotionPrice.HasValue && promo.OriginalPrice.HasValue)
            {
                <div class="promo-seller-only">
                    <span>Descuento asumido por el vendedor</span>
                </div>
            }
        </div>
    };

    private void CloseItemModal()
    {
        showItemModal = false;
        selectedItem = null;
    }

    private async Task SaveItem()
    {
        if (selectedItem is null) return;

        isSaving = true;
        StateHasChanged();

        try
        {
            // Build request with only changed fields
            var request = new UpdateMeliItemRequest();
            bool hasChanges = false;

            if (editTitle != selectedItem.Title)
            {
                request.Title = editTitle;
                hasChanges = true;
            }
            if (editPrice != selectedItem.Price)
            {
                request.Price = editPrice;
                hasChanges = true;
            }
            if (editStock != selectedItem.AvailableQuantity)
            {
                request.AvailableQuantity = editStock;
                hasChanges = true;
            }
            if (editStatus != selectedItem.Status)
            {
                request.Status = editStatus;
                hasChanges = true;
            }

            if (!hasChanges)
            {
                ToastService.Info("No hay cambios para guardar");
                isSaving = false;
                return;
            }

            var updated = await Api.UpdateMeliItemAsync(selectedItem.MeliItemId, request);
            if (updated is not null && items is not null)
            {
                // Replace item in local list
                var idx = items.FindIndex(i => i.MeliItemId == selectedItem.MeliItemId);
                if (idx >= 0)
                    items[idx] = updated;

                selectedItem = updated;
                editTitle = updated.Title;
                editPrice = updated.Price;
                editPriceFormatted = FormatPrice(editPrice);
                editStock = updated.AvailableQuantity;
                editStatus = updated.Status;

                ToastService.Success("Publicacion actualizada");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar: " + ex.Message);
        }

        isSaving = false;
    }

    private string GetConditionLabel(string? condition) => condition switch
    {
        "new" => "Nuevo",
        "used" => "Usado",
        "not_specified" => "No especificado",
        _ => condition ?? "-"
    };

