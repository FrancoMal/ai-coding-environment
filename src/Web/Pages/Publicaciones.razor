@code {
    private List<MeliItemDto>? items;
    private bool isLoading = true;
    private bool isSyncing;
    private int totalItems;

    // View mode
    private string viewMode = "flat";

    // Sort state
    private string? sortColumn;
    private bool sortAsc = true;

    // Text filter state
    private Dictionary<string, string> textFilters = new();

    // Checkbox filter state
    private string? activeFilterColumn;
    private Dictionary<string, HashSet<string>> checkboxFilters = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Api.GetMeliItemsAsync();
            if (response is not null)
            {
                items = response.Items;
                totalItems = response.Total;
            }
        }
        catch
        {
            ToastService.Error("Error al cargar las publicaciones");
            items = new();
        }

        isLoading = false;
    }

    private async Task SyncItems()
    {
        isSyncing = true;
        StateHasChanged();

        try
        {
            var result = await Api.SyncMeliItemsAsync();
            if (result is not null)
            {
                if (result.TotalErrors > 0)
                    ToastService.Warning($"Sincronizados {result.TotalSynced} items con {result.TotalErrors} errores");
                else
                    ToastService.Success($"Sincronizados {result.TotalSynced} items");
            }
            await LoadItems();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al sincronizar: " + ex.Message);
        }

        isSyncing = false;
    }

    // --- Sort ---
    private void ToggleSort(string column)
    {
        if (sortColumn == column)
            sortAsc = !sortAsc;
        else
        {
            sortColumn = column;
            sortAsc = true;
        }
    }

    // --- Text Filters ---
    private void SetTextFilter(string column, string value)
    {
        textFilters[column] = value;
    }

    private string GetTextFilter(string column)
    {
        return textFilters.TryGetValue(column, out var val) ? val : "";
    }

    private bool IsFilterActive(string column)
    {
        return textFilters.TryGetValue(column, out var tv) && !string.IsNullOrEmpty(tv);
    }

    // --- Checkbox Filters ---
    private void ToggleDropdownFilter(string column)
    {
        if (activeFilterColumn == column)
            activeFilterColumn = null;
        else
            activeFilterColumn = column;
    }

    private void ToggleCheckboxValue(string column, string value)
    {
        if (!checkboxFilters.ContainsKey(column))
            checkboxFilters[column] = new HashSet<string>();
        if (!checkboxFilters[column].Remove(value))
            checkboxFilters[column].Add(value);
    }

    private bool IsCheckboxChecked(string column, string value)
    {
        return checkboxFilters.TryGetValue(column, out var set) && set.Contains(value);
    }

    private bool IsCheckboxFilterActive(string column)
    {
        return checkboxFilters.TryGetValue(column, out var cv) && cv.Count > 0;
    }

    private List<string> GetUniqueValues(string column)
    {
        if (items is null) return new();
        var values = column switch
        {
            "estado" => items.Select(i => GetStatusLabel(i.Status)).Distinct(),
            "tipo" => items.Select(i => GetListingTypeLabel(i.ListingTypeId)).Distinct(),
            "cuenta" => items.Select(i => i.AccountNickname).Distinct(),
            _ => Enumerable.Empty<string>()
        };
        return values.OrderBy(v => v).ToList();
    }

    private void ClearCheckboxFilter(string column)
    {
        checkboxFilters.Remove(column);
        activeFilterColumn = null;
    }

    private void CloseAllDropdowns()
    {
        activeFilterColumn = null;
    }

    // --- Filtered + Sorted ---
    private List<MeliItemDto> GetFilteredAndSortedItems()
    {
        if (items is null) return new();

        var filtered = items.AsEnumerable();

        // Text filters
        foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var search = kv.Value;
            filtered = kv.Key switch
            {
                "titulo" => filtered.Where(i => i.Title.Contains(search, StringComparison.OrdinalIgnoreCase)),
                "sku" => filtered.Where(i => (i.Sku ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                _ => filtered
            };
        }

        // Checkbox filters
        foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
        {
            var values = kv.Value;
            filtered = kv.Key switch
            {
                "estado" => filtered.Where(i => values.Contains(GetStatusLabel(i.Status))),
                "tipo" => filtered.Where(i => values.Contains(GetListingTypeLabel(i.ListingTypeId))),
                "cuenta" => filtered.Where(i => values.Contains(i.AccountNickname)),
                _ => filtered
            };
        }

        var list = filtered.ToList();

        // Sort
        if (sortColumn is not null)
        {
            list = sortColumn switch
            {
                "titulo" => sortAsc ? list.OrderBy(i => i.Title).ToList() : list.OrderByDescending(i => i.Title).ToList(),
                "sku" => sortAsc ? list.OrderBy(i => i.Sku).ToList() : list.OrderByDescending(i => i.Sku).ToList(),
                "precio" => sortAsc ? list.OrderBy(i => i.Price).ToList() : list.OrderByDescending(i => i.Price).ToList(),
                "stock" => sortAsc ? list.OrderBy(i => i.AvailableQuantity).ToList() : list.OrderByDescending(i => i.AvailableQuantity).ToList(),
                "vendidos" => sortAsc ? list.OrderBy(i => i.SoldQuantity).ToList() : list.OrderByDescending(i => i.SoldQuantity).ToList(),
                "estado" => sortAsc ? list.OrderBy(i => i.Status).ToList() : list.OrderByDescending(i => i.Status).ToList(),
                "tipo" => sortAsc ? list.OrderBy(i => i.ListingTypeId).ToList() : list.OrderByDescending(i => i.ListingTypeId).ToList(),
                "cuenta" => sortAsc ? list.OrderBy(i => i.AccountNickname).ToList() : list.OrderByDescending(i => i.AccountNickname).ToList(),
                _ => list
            };
        }

        return list;
    }

    // --- Grouping ---
    private List<FamilyGroup> GetFamilyGroups()
    {
        var filtered = GetFilteredAndSortedItems();
        return filtered
            .GroupBy(i => i.FamilyId ?? "__none__")
            .Select(g => new FamilyGroup
            {
                FamilyId = g.Key,
                FamilyName = g.First().FamilyName ?? "Sin familia",
                Items = g.ToList()
            })
            .OrderBy(g => g.FamilyName == "Sin familia" ? 1 : 0)
            .ThenBy(g => g.FamilyName)
            .ToList();
    }

    private List<ProductGroup> GetProductGroups()
    {
        var filtered = GetFilteredAndSortedItems();
        return filtered
            .GroupBy(i => i.UserProductId ?? i.MeliItemId)
            .Select(g => new ProductGroup
            {
                UserProductId = g.Key,
                Title = g.First().Title,
                Items = g.ToList()
            })
            .OrderBy(g => g.Title)
            .ToList();
    }

    // --- Helpers ---
    private string GetStatusClass(string status) => status switch
    {
        "active" => "status-active",
        "paused" => "status-paused",
        "closed" => "status-closed",
        "under_review" => "status-review",
        "inactive" => "status-closed",
        _ => ""
    };

    private string GetStatusLabel(string status) => status switch
    {
        "active" => "Activa",
        "paused" => "Pausada",
        "closed" => "Cerrada",
        "under_review" => "En revision",
        "inactive" => "Inactiva",
        _ => status
    };

    private string GetListingTypeLabel(string? type) => type switch
    {
        "gold_special" => "Premium",
        "gold_pro" => "Oro Pro",
        "gold" => "Oro",
        "silver" => "Plata",
        "bronze" => "Bronce",
        "free" => "Gratis",
        _ => type ?? "-"
    };

    private string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "...";

    // --- Item detail modal ---
    private MeliItemDto? selectedItem;
    private bool showItemModal;
    private bool isSaving;
    private string editTitle = "";
    private decimal editPrice;
    private int editStock;
    private string editStatus = "";

    private void OpenItemModal(MeliItemDto item)
    {
        selectedItem = item;
        editTitle = item.Title;
        editPrice = item.Price;
        editStock = item.AvailableQuantity;
        editStatus = item.Status;
        showItemModal = true;
    }

    private void CloseItemModal()
    {
        showItemModal = false;
        selectedItem = null;
    }

    private async Task SaveItem()
    {
        if (selectedItem is null) return;

        isSaving = true;
        StateHasChanged();

        try
        {
            // Build request with only changed fields
            var request = new UpdateMeliItemRequest();
            bool hasChanges = false;

            if (editTitle != selectedItem.Title)
            {
                request.Title = editTitle;
                hasChanges = true;
            }
            if (editPrice != selectedItem.Price)
            {
                request.Price = editPrice;
                hasChanges = true;
            }
            if (editStock != selectedItem.AvailableQuantity)
            {
                request.AvailableQuantity = editStock;
                hasChanges = true;
            }
            if (editStatus != selectedItem.Status)
            {
                request.Status = editStatus;
                hasChanges = true;
            }

            if (!hasChanges)
            {
                ToastService.Info("No hay cambios para guardar");
                isSaving = false;
                return;
            }

            var updated = await Api.UpdateMeliItemAsync(selectedItem.MeliItemId, request);
            if (updated is not null && items is not null)
            {
                // Replace item in local list
                var idx = items.FindIndex(i => i.MeliItemId == selectedItem.MeliItemId);
                if (idx >= 0)
                    items[idx] = updated;

                selectedItem = updated;
                editTitle = updated.Title;
                editPrice = updated.Price;
                editStock = updated.AvailableQuantity;
                editStatus = updated.Status;

                ToastService.Success("Publicacion actualizada");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar: " + ex.Message);
        }

        isSaving = false;
    }

    private string GetConditionLabel(string? condition) => condition switch
    {
        "new" => "Nuevo",
        "used" => "Usado",
        "not_specified" => "No especificado",
        _ => condition ?? "-"
    };

    // --- Group classes ---
    private class FamilyGroup
    {
        public string FamilyId { get; set; } = "";
        public string? FamilyName { get; set; }
        public List<MeliItemDto> Items { get; set; } = new();
    }

    private class ProductGroup
    {
        public string UserProductId { get; set; } = "";
        public string Title { get; set; } = "";
        public List<MeliItemDto> Items { get; set; } = new();
    }
}
