@page "/publicaciones"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Publicaciones de MercadoLibre (@GetFilteredAndSortedItems().Count de @totalItems)</h3>
        <div class="sync-dropdown-wrapper">
            <button class="btn btn-primary" @onclick="() => SyncItems(null, null)" disabled="@isSyncing" style="border-radius: 6px 0 0 6px;">
                @(isSyncing ? syncingLabel : "Sincronizar")
            </button>
            <button class="btn btn-primary sync-dropdown-toggle" @onclick="ToggleSyncMenu" @onclick:stopPropagation="true" disabled="@isSyncing"
                    style="border-radius: 0 6px 6px 0; border-left: 1px solid rgba(255,255,255,0.3); padding: 0.5rem 0.4rem;">
                ▾
            </button>
            @if (showSyncMenu)
            {
                <div class="sync-dropdown-menu">
                    <div class="sync-dropdown-section">Por estado</div>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("active", null)'>
                        <span class="status-dot dot-active"></span> Solo activas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("paused", null)'>
                        <span class="status-dot dot-paused"></span> Solo pausadas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("closed", null)'>
                        <span class="status-dot dot-closed"></span> Solo cerradas
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <div class="sync-dropdown-section">Por cuenta</div>
                    @if (meliAccounts is not null)
                    {
                        @foreach (var acc in meliAccounts)
                        {
                            var a = acc;
                            <button class="sync-dropdown-item" @onclick="() => SyncItems(null, a.Id)">
                                👤 @a.Nickname
                            </button>
                        }
                    }
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item sync-item-all" @onclick='() => SyncItems(null, null)'>
                        🔄 Sincronizar todo
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando publicaciones...</p>
        }
        else if (items is null || !items.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay publicaciones. Hace clic en "Sincronizar" para traer los items de MercadoLibre.</p>
        }
        else
        {
            <!-- View mode toggle -->
            <div class="view-mode-bar">
                <div style="display: flex; gap: 0.25rem;">
                    <button class="view-mode-btn @(viewMode == "flat" ? "active" : "")" @onclick='() => viewMode = "flat"'>Lista</button>
                    <button class="view-mode-btn @(viewMode == "family" ? "active" : "")" @onclick='() => viewMode = "family"'>Por Familia</button>
                    <button class="view-mode-btn @(viewMode == "product" ? "active" : "")" @onclick='() => viewMode = "product"'>Por Producto</button>
                </div>
                <button class="promo-filter-btn @(filterPromo ? "active" : "")" @onclick="TogglePromoFilter" title="Filtrar publicaciones en promocion">
                    🏷️ En promocion @(filterPromo ? $"({GetFilteredAndSortedItems().Count})" : "")
                </button>
            </div>

            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <!-- Imagen -->
                            <th class="th-img">Img</th>
                            <!-- Titulo: text input -->
                            <th class="th-filterable" style="min-width: 200px;">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("titulo") ? "has-filter" : "")" placeholder="Titulo, ID, Familia..."
                                           value='@GetTextFilter("titulo")' @oninput='(e) => SetTextFilter("titulo", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("titulo")' title="Ordenar">
                                        <span class="@(sortColumn == "titulo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "titulo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- SKU: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("sku") ? "has-filter" : "")" placeholder="SKU"
                                           value='@GetTextFilter("sku")' @oninput='(e) => SetTextFilter("sku", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("sku")' title="Ordenar">
                                        <span class="@(sortColumn == "sku" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "sku" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Precio: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("precio")'>
                                <div class="th-inner">
                                    <span class="th-label">Precio</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "precio" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "precio" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Stock: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("stock")'>
                                <div class="th-inner">
                                    <span class="th-label">Stock</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "stock" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "stock" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Vendidos: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("vendidos")'>
                                <div class="th-inner">
                                    <span class="th-label">Vendidos</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "vendidos" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "vendidos" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Estado: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "estado" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("estado")'>Estado</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("estado")'>
                                            <span class="@(sortColumn == "estado" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "estado" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("estado") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("estado")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "estado")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("estado"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("estado", v)" @onchange='() => ToggleCheckboxValue("estado", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("estado"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("estado")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Tipo: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "tipo" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("tipo")'>Tipo</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("tipo")'>
                                            <span class="@(sortColumn == "tipo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "tipo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("tipo") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("tipo")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "tipo")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("tipo"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("tipo", v)" @onchange='() => ToggleCheckboxValue("tipo", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("tipo"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("tipo")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Cuenta: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "cuenta" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("cuenta")'>Cuenta</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("cuenta")'>
                                            <span class="@(sortColumn == "cuenta" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "cuenta" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("cuenta") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("cuenta")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "cuenta")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("cuenta"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("cuenta", v)" @onchange='() => ToggleCheckboxValue("cuenta", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("cuenta"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("cuenta")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (viewMode == "flat")
                        {
                            @foreach (var item in GetFilteredAndSortedItems())
                            {
                                <tr class="clickable-row" @onclick="() => OpenItemModal(item)">
                                    <td style="text-align: center;">
                                        @if (!string.IsNullOrEmpty(item.Thumbnail))
                                        {
                                            <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                        }
                                        else
                                        {
                                            <div class="item-thumb-placeholder">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Permalink))
                                        {
                                            <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                        }
                                        else
                                        {
                                            <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                        }
                                        <div class="item-id">@item.MeliItemId</div>
                                    </td>
                                    <td>@(item.Sku ?? "-")</td>
                                    <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                    <td>@item.AvailableQuantity</td>
                                    <td>@item.SoldQuantity</td>
                                    <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                    <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                    <td>@item.AccountNickname</td>
                                </tr>
                            }
                        }
                        else if (viewMode == "family")
                        {
                            @foreach (var family in GetFamilyGroups())
                            {
                                <tr class="group-header-row">
                                    <td colspan="9">
                                        <strong>@(family.FamilyName ?? "Sin familia")</strong>
                                        <small class="text-muted" style="margin-left: 0.5rem;">(@family.Items.Count items)</small>
                                    </td>
                                </tr>
                                @foreach (var item in family.Items)
                                {
                                    <tr class="group-item-row clickable-row" @onclick="() => OpenItemModal(item)">
                                        <td style="text-align: center;">
                                            @if (!string.IsNullOrEmpty(item.Thumbnail))
                                            {
                                                <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                            }
                                            else
                                            {
                                                <div class="item-thumb-placeholder">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Permalink))
                                            {
                                                <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                            }
                                            else
                                            {
                                                <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                            }
                                            <div class="item-id">@item.MeliItemId</div>
                                        </td>
                                        <td>@(item.Sku ?? "-")</td>
                                        <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                        <td>@item.AvailableQuantity</td>
                                        <td>@item.SoldQuantity</td>
                                        <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                        <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                        <td>@item.AccountNickname</td>
                                    </tr>
                                }
                            }
                        }
                        else if (viewMode == "product")
                        {
                            @foreach (var product in GetProductGroups())
                            {
                                @if (product.Items.Count > 1)
                                {
                                    <tr class="group-header-row">
                                        <td colspan="9">
                                            <strong>@Truncate(product.Title, 60)</strong>
                                            <small class="text-muted" style="margin-left: 0.5rem;">(@product.Items.Count variaciones)</small>
                                        </td>
                                    </tr>
                                    @foreach (var item in product.Items)
                                    {
                                        <tr class="group-item-row clickable-row" @onclick="() => OpenItemModal(item)">
                                            <td style="text-align: center;">
                                                @if (!string.IsNullOrEmpty(item.Thumbnail))
                                                {
                                                    <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                                }
                                                else
                                                {
                                                    <div class="item-thumb-placeholder">
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Permalink))
                                                {
                                                    <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                                }
                                                else
                                                {
                                                    <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                                }
                                                <div class="item-id">@item.MeliItemId</div>
                                            </td>
                                            <td>@(item.Sku ?? "-")</td>
                                            <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                            <td>@item.AvailableQuantity</td>
                                            <td>@item.SoldQuantity</td>
                                            <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                            <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                            <td>@item.AccountNickname</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    var item = product.Items[0];
                                    <tr class="clickable-row" @onclick="() => OpenItemModal(item)">
                                        <td style="text-align: center;">
                                            @if (!string.IsNullOrEmpty(item.Thumbnail))
                                            {
                                                <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                            }
                                            else
                                            {
                                                <div class="item-thumb-placeholder">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Permalink))
                                            {
                                                <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                            }
                                            else
                                            {
                                                <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                            }
                                            <div class="item-id">@item.MeliItemId</div>
                                        </td>
                                        <td>@(item.Sku ?? "-")</td>
                                        <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                        <td>@item.AvailableQuantity</td>
                                        <td>@item.SoldQuantity</td>
                                        <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                        <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                        <td>@item.AccountNickname</td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showSyncMenu)
{
    <div class="filter-overlay" @onclick="() => showSyncMenu = false"></div>
}

@if (activeFilterColumn is not null)
{
    <div class="filter-overlay" @onclick="CloseAllDropdowns"></div>
}

@if (showItemModal && selectedItem is not null)
{
    <div class="modal-overlay" @onclick="CloseItemModal">
        <div class="modal-card modal-item-detail" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Detalle de Publicacion</h3>
                <button class="modal-close" @onclick="CloseItemModal">&times;</button>
            </div>
            <div class="modal-body">
                <!-- Header: thumbnail + meta -->
                @if (!string.IsNullOrEmpty(selectedItem.CategoryPath) || !string.IsNullOrEmpty(selectedItem.CategoryId))
                {
                    <div style="font-size: 0.72rem; color: #9ca3af; margin-bottom: 0.2rem;">
                        @(selectedItem.CategoryPath ?? selectedItem.CategoryId) (@selectedItem.CategoryId)
                    </div>
                }
                <div style="margin-bottom: 0.75rem;">
                    <input type="text" class="form-input" @bind="editFamilyName" style="font-weight: 700; font-size: 1.05rem;" />
                </div>
                <div class="item-detail-header">
                    <div class="item-detail-thumb">
                        @if (!string.IsNullOrEmpty(selectedItem.Thumbnail))
                        {
                            <img src="@selectedItem.Thumbnail" alt="" />
                        }
                        else
                        {
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                        }
                    </div>
                    <div class="item-detail-meta">
                        <span class="item-detail-meli-id">@selectedItem.MeliItemId</span>
                        @if (!string.IsNullOrEmpty(selectedItem.Permalink))
                        {
                            <a href="@selectedItem.Permalink" target="_blank" class="item-detail-link">Ver en MercadoLibre ↗</a>
                        }
                        <span class="status-badge @GetStatusClass(selectedItem.Status)" style="width: fit-content;">@GetStatusLabel(selectedItem.Status)</span>
                        <span style="font-size: 0.8rem; color: #6b7280;">Cuenta: @selectedItem.AccountNickname</span>
                    </div>
                    <div style="font-size: 1.15rem; font-weight: 600; color: #374151; flex: 1; margin-left: 35px;">
                        @selectedItem.Title
                    </div>
                </div>
                <!-- Info + Cost Simulator side by side -->
                <div class="info-costs-row">
                    <div class="info-costs-left">
                        <div class="detail-section" style="margin-bottom: 0;">
                            <h4>Informacion</h4>
                            <div class="detail-info-grid">
                                <div class="detail-info-item">
                                    <span class="detail-label">SKU</span>
                                    <span class="detail-value">@(selectedItem.Sku ?? "-")</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Vendidos</span>
                                    <span class="detail-value">@selectedItem.SoldQuantity</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Tipo publicacion</span>
                                    <span class="detail-value">@GetListingTypeLabel(selectedItem.ListingTypeId) @GetInstallmentLabel(selectedItem.ListingTypeId, selectedItem.InstallmentTag)</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Creada</span>
                                    <span class="detail-value">@(selectedItem.DateCreated?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Ultima actualizacion</span>
                                    <span class="detail-value">@(selectedItem.LastUpdated?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="info-costs-right">
                        <div class="cost-simulator">
                            <h4>Simulador de costos</h4>
                            @if (isLoadingCosts)
                            {
                                <div class="cost-loading"><span>Calculando costos...</span></div>
                            }
                            else if (itemCosts is not null)
                            {
                                <div class="cost-price-box">
                                    <span class="cost-price-label">Precio</span>
                                    <span class="cost-price-value">$ @itemCosts.Price.ToString("N2", argCulture)</span>
                                </div>
                                <div class="cost-line-items">
                                    <div class="cost-line">
                                        <span class="cost-line-label">Cargo por vender</span>
                                        <span class="cost-line-amount negative">-$ @((itemCosts.SaleFeeAmount - itemCosts.FixedFee).ToString("N2", argCulture))</span>
                                    </div>
                                    <div class="cost-line">
                                        <span class="cost-line-label">Costo fijo</span>
                                        <span class="cost-line-amount negative">-$ @itemCosts.FixedFee.ToString("N2", argCulture)</span>
                                    </div>
                                    <div class="cost-line">
                                        <div>
                                            <span class="cost-line-label">Costo por ofrecer cuotas</span>
                                            @if (itemCosts.FinancingFee == 0)
                                            {
                                                <div class="cost-line-sub">Sin cuotas agregadas</div>
                                            }
                                        </div>
                                        <span class="cost-line-amount">$ @itemCosts.FinancingFee.ToString("N2", argCulture)</span>
                                    </div>
                                    <div class="cost-line">
                                        <div>
                                            <span class="cost-line-label">Costo por envio</span>
                                            <div class="cost-line-sub">Envios de Mercado Libre</div>
                                        </div>
                                        <span class="cost-line-amount negative">-$ @itemCosts.ShippingCost.ToString("N2", argCulture)</span>
                                    </div>
                                    <div class="cost-line cost-line-tax">
                                        <div>
                                            <span class="cost-line-label">Retenciones</span>
                                            <div class="cost-line-sub">% sobre el precio</div>
                                        </div>
                                        <div class="cost-tax-input">
                                            <input type="text" class="cost-tax-field" value="@FormatTaxPct()" @oninput="OnTaxPercentageChanged" inputmode="decimal" />
                                            <span class="cost-tax-pct">%</span>
                                            <span class="cost-line-amount negative" style="margin-left: 0.5rem;">-$ @(CalculateTaxAmount().ToString("N2", argCulture))</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="cost-total">
                                    <span class="cost-total-label">Recibis</span>
                                    <span class="cost-total-value">$ @(CalculateNetAmount().ToString("N2", argCulture))</span>
                                </div>
                            }
                            else
                            {
                                <div class="cost-loading"><span>No se pudieron obtener los costos</span></div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Editable fields -->
                <div class="detail-section">
                    @if (isLoadingPromotions)
                    {
                        <div class="promo-campaigns-loading">
                            <span>Cargando detalles de campañas...</span>
                        </div>
                    }
                    else if (itemPromotions is not null && itemPromotions.Any())
                    {
                        var activeCampaigns = itemPromotions.Where(p => p.Status == "started").ToList();
                        var otherCampaigns = itemPromotions.Where(p => p.Status != "started").ToList();

                        @if (activeCampaigns.Any())
                        {
                            <div class="promo-campaigns">
                                <span class="promo-campaigns-title">Campañas activas (@activeCampaigns.Count)</span>
                                @foreach (var promo in activeCampaigns)
                                {
                                    @RenderCampaignCard(promo)
                                }
                            </div>
                        }

                        @if (otherCampaigns.Any())
                        {
                            <div class="promo-campaigns promo-campaigns-other">
                                <button class="promo-collapse-toggle" @onclick="() => showOtherCampaigns = !showOtherCampaigns">
                                    <span>Otras campañas disponibles (@otherCampaigns.Count)</span>
                                    <span class="promo-collapse-icon">@(showOtherCampaigns ? "▲" : "▼")</span>
                                </button>
                                @if (showOtherCampaigns)
                                {
                                    @foreach (var promo in otherCampaigns)
                                    {
                                        @RenderCampaignCard(promo)
                                    }
                                }
                            </div>
                        }
                    }
                    else if (itemPromotions is not null && !itemPromotions.Any())
                    {
                        <div class="promo-campaigns-empty">
                            <span>No se encontraron campañas asociadas</span>
                        </div>
                    }
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Precio original (@selectedItem.CurrencyId)</label>
                            <div style="position: relative;"><span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span><input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@editPriceFormatted" @oninput="OnPriceInput" inputmode="decimal" /></div>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Stock</label>
                            <input type="number" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right;" @bind="editStock" min="0" />
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Estado</label>
                            <div class="status-toggle">
                                <button class="status-toggle-btn @(editStatus == "active" ? "active-btn" : "")" @onclick='() => editStatus = "active"'>Activa</button>
                                <button class="status-toggle-btn @(editStatus == "paused" ? "paused-btn" : "")" @onclick='() => editStatus = "paused"'>Pausada</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseItemModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveItem" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

